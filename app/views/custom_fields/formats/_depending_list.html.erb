<p>
  <%= f.text_area :possible_values, :value => @custom_field.possible_values.to_a.join("\n"), :rows => 15, :required => true %>
  <em class="info"><%= l(:text_custom_field_possible_values_info) %></em>
</p>
<% parent_type = @custom_field.parent_field_type.presence || (@custom_field.parent_field_key.present? ? 'core_field' : (@custom_field.parent_custom_field_id.present? ? 'custom_field' : '')) %>
<% parent_reference = RedmineDependingCustomFields::ParentReference.from_custom_field(@custom_field) %>
<% if parent_reference.blank? %>
  <p><%= f.text_field(:default_value) %></p>
<% end %>
<p><%= f.text_field :url_pattern, :size => 50, :label => :label_link_values_to %></p>
<p>
  <%= f.select :parent_field_type,
               [
                 [l(:label_parent_field_type_custom), 'custom_field'],
                 [l(:label_parent_field_type_core), 'core_field']
               ],
               { include_blank: true, selected: parent_type },
               data: { parent_type_toggle: true },
               label: :field_parent_field_type %>
</p>
<p class="depending-parent-field depending-parent-custom">
  <%= f.select :parent_custom_field_id,
               CustomField.where(type: @custom_field.type,
                                    field_format: ['list', RedmineDependingCustomFields::FIELD_FORMAT_DEPENDING_LIST])
                          .where.not(id: @custom_field.id)
                          .order(:position)
                          .map { |cf| [cf.name, cf.id.to_s] },
               { include_blank: true },
               label: :field_parent_custom_field_id %>
</p>
<p class="depending-parent-field depending-parent-core">
  <%= f.select :parent_field_key,
               RedmineDependingCustomFields::ParentValueOptions.core_field_options,
               { include_blank: true },
               label: :field_parent_field_key %>
</p>
<% if parent_reference.present? %>
  <% if parent_reference.enumerated? %>
    <%= render partial: 'custom_fields/formats/dependencies_matrix',
               locals: { parent_label: parent_reference.label, parent_options: parent_reference.options, custom_field: @custom_field } %>
    <%= render partial: 'custom_fields/formats/default_dependencies',
               locals: { parent_label: parent_reference.label, parent_options: parent_reference.options, custom_field: @custom_field } %>
  <% else %>
    <%= render partial: 'custom_fields/formats/dependencies_rules',
               locals: { custom_field: @custom_field, f: f, parent_format: parent_reference.format } %>
  <% end %>
<% end %>
<p><%= f.check_box :hide_when_disabled, label: :field_hide_when_disabled %></p>
<p><%= edit_tag_style_tag f %></p>
